{
  "annotations": { "list": [] },
  "description": "ZFS pool stats (ARC + datasets) — node-exporter zfs collector",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "zfs-pool",
  "title": "ZFS Pool",
  "tags": ["homelab", "zfs"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "ARC size",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_zfs_arc_size",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "ARC max",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_zfs_arc_c_max",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "ARC hit ratio (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(node_zfs_arc_hits[5m]) / (rate(node_zfs_arc_hits[5m]) + rate(node_zfs_arc_misses[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "ARC throttled",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(node_zfs_arc_memory_throttle_count[1h])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "ARC size vs cap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "table", "showLegend": true, "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "node_zfs_arc_size", "legendFormat": "size", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "node_zfs_arc_c_max", "legendFormat": "cap", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "node_zfs_arc_c_min", "legendFormat": "min", "refId": "C" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "ARC hits vs misses (rate/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "showLegend": true, "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(node_zfs_arc_hits[2m])", "legendFormat": "hits", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(node_zfs_arc_misses[2m])", "legendFormat": "misses", "refId": "B" }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "ZFS pool space (filesystem view)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "table", "showLegend": true, "placement": "right" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_filesystem_size_bytes{fstype=\"zfs\"}",
          "legendFormat": "{{mountpoint}} size",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_filesystem_size_bytes{fstype=\"zfs\"} - node_filesystem_avail_bytes{fstype=\"zfs\"}",
          "legendFormat": "{{mountpoint}} used",
          "refId": "B"
        }
      ]
    },
    {
      "id": 30,
      "type": "table",
      "title": "Dataset usage (current)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1 - (node_filesystem_avail_bytes{fstype=\"zfs\"} / node_filesystem_size_bytes{fstype=\"zfs\"})",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
